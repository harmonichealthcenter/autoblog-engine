# Required
ANTHROPIC_API_KEY=sk-ant-...

# Replicate image generation (FLUX). Required for blog hero images.
# Without it, the pipeline still generates the article and frontmatter, but skips images.
# Default model: black-forest-labs/flux-schnell (~$0.003/image, 1-2s).
REPLICATE_API_TOKEN=r8_...

# Slack (optional in v1, fill in when webhook is ready)
SLACK_WEBHOOK_URL=

# Per-site GitHub publish targets. Format: SITE_<NAME>_GITHUB_TOKEN, SITE_<NAME>_GITHUB_REPO
# The repo is "owner/name". Token needs contents:write on that repo.
SITE_QIARI_GITHUB_TOKEN=
SITE_QIARI_GITHUB_REPO=

# Qicoil.com publish target. Repo is "owner/name" (e.g. harmonichealthcenter/qicoil-main).
# Token needs contents:write on that repo. Drafts land at content/blog/ on the configured branch.
SITE_QICOIL_GITHUB_TOKEN=
SITE_QICOIL_GITHUB_REPO=

# Cron control. Set to "false" to disable scheduled generation (review/publish CLIs still work).
CRON_ENABLED=true

# Path to sqlite db. Defaults to ./data/autoblog.db
DB_PATH=./data/autoblog.db
